        "type": "String",
        "defaultValue": "default"
      }
    },
    "variables": {
      "return_value": {
        "type": "String",
        "defaultValue": ""
      },
      "status_flag": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "RunChildPipeline",
        "type": "ExecutePipeline",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "child_etl",
            "type": "PipelineReference"
          },
          "parameters": {
            "input": {
              "type": "Expression",
              "value": "@pipeline().parameters.input_param"
