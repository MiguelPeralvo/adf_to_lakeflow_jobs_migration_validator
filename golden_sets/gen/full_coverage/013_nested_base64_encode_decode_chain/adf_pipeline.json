{
  "name": "nested_base64_encode_decode_chain",
  "properties": {
    "parameters": {
      "payload_body": {
        "type": "String",
        "defaultValue": "hello_world"
      },
      "secret_key": {
        "type": "String",
        "defaultValue": "my_secret_key_123"
      },
      "env": {
        "type": "String",
        "defaultValue": "dev"
      }
    },
    "variables": {
      "encoded_payload": {
        "type": "String",
        "defaultValue": ""
      },
      "double_encoded_payload": {
        "type": "String",
        "defaultValue": ""
      },
      "decoded_verification": {
        "type": "String",
        "defaultValue": ""
      },
      "final_result": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "EncodePayloadWithKey",
        "type": "SetVariable",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "variableName": "encoded_payload",
          "value": {
            "type": "Expression",
            "value": "@base64(concat(pipeline().parameters.payload_body, ':', pipeline().parameters.secret_key, ':', pipeline().parameters.env))"
          }
        }
      },
      {
        "name": "DoubleEncodePayload",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "EncodePayloadWithKey",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "variableName": "double_encoded_payload",
          "value": {
            "type": "Expression",
            "value": "@base64(concat('v2:', base64(concat(pipeline().parameters.env, '|', pipeline().parameters.payload_body)), ':', base64(concat(pipeline().parameters.secret_key, '_', pipeline().parameters.env))))"
          }
        }
      },
      {
        "name": "DecodeAndVerify",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "DoubleEncodePayload",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "variableName": "decoded_verification",
          "value": {
            "type": "Expression",
            "value": "@base64ToString(base64(concat(base64ToString(base64(concat(pipeline().parameters.payload_body, ':', pipeline().parameters.secret_key))), ':', pipeline().parameters.env)))"
          }
        }
      },
      {
        "name": "PostEncodedPayloadToEndpoint",
        "type": "WebActivity",
        "dependsOn": [
          {
            "activity": "DecodeAndVerify",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "url": {
            "type": "Expression",
            "value": "@concat('https://api.example.com/', pipeline().parameters.env, '/ingest')"
          },
          "method": "POST",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": {
              "type": "Expression",
              "value": "@concat('Basic ', base64(concat(pipeline().parameters.secret_key, ':', base64ToString(base64(pipeline().parameters.env)))))"
            }
          },
          "body": {
            "type": "Expression",
            "value": "@json(concat('{\"encoded_payload\":\"', variables('double_encoded_payload'), '\",\"verification_hash\":\"', base64(concat(variables('decoded_verification'), ':', base64ToString(base64(concat(pipeline().parameters.env, '_', pipeline().parameters.secret_key))))), '\",\"environment\":\"', pipeline().parameters.env, '\"}'))"
          },
          "timeout": "00:01:00"
        }
      },
      {
        "name": "SetFinalResult",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "PostEncodedPayloadToEndpoint",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "variableName": "final_result",
          "value": {
            "type": "Expression",
            "value": "@concat('status=success;env=', pipeline().parameters.env, ';original_decoded=', base64ToString(base64(concat(pipeline().parameters.payload_body, ':', pipeline().parameters.secret_key, ':', pipeline().parameters.env))), ';nested_check=', base64ToString(base64(concat(base64ToString(variables('double_encoded_payload')), '|', base64(concat('final_', pipeline().parameters.env)))))"
          }
        }
      }
    ]
  }
}