{
  "name": "nested_foreach_with_inner_expressions",
  "properties": {
    "parameters": {
      "source_tables": {
        "type": "Array",
        "defaultValue": [
          "customers",
          "orders"
        ]
      },
      "env": {
        "type": "String",
        "defaultValue": "dev"
      },
      "batch_id": {
        "type": "String",
        "defaultValue": "B001"
      }
    },
    "variables": {
      "combined_tables": {
        "type": "Array",
        "defaultValue": []
      },
      "current_table": {
        "type": "String",
        "defaultValue": ""
      },
      "processing_flag": {
        "type": "String",
        "defaultValue": "false"
      }
    },
    "activities": [
      {
        "name": "LookupAdditionalTables",
        "type": "Lookup",
        "dependsOn": [],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sql_reader_query": {
              "type": "Expression",
              "value": "@concat('SELECT table_name FROM metadata.pipeline_tables WHERE env = ''', pipeline().parameters.env, ''' AND batch_id = ''', pipeline().parameters.batch_id, '''')"
            }
          },
          "dataset": {
            "referenceName": "ds_sql_metadata",
            "type": "DatasetReference"
          },
          "firstRowOnly": false
        },
        "input_dataset_definitions": [
          {
            "type": "AzureSqlSource",
            "schema": [],
            "linkedServiceName": {
              "referenceName": "ls_sql",
              "type": "LinkedServiceReference"
            }
          }
        ]
      },
      {
        "name": "SetCombinedTables",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "LookupAdditionalTables",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "combined_tables",
          "value": {
            "type": "Expression",
            "value": "@union(createArray(json(concat('{\"name\":\"', pipeline().parameters.source_tables[0], '\",\"env\":\"', pipeline().parameters.env, '\",\"batch_id\":\"', pipeline().parameters.batch_id, '\"}'))), createArray(json(concat('{\"name\":\"', pipeline().parameters.source_tables[1], '\",\"env\":\"', pipeline().parameters.env, '\",\"batch_id\":\"', pipeline().parameters.batch_id, '\"}'))))"
          }
        }
      },
      {
        "name": "ForEachCombinedTable",
        "type": "ForEach",
        "dependsOn": [
          {
            "activity": "SetCombinedTables",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "isSequential": false,
          "batchCount": 4,
          "items": {
            "type": "Expression",
            "value": "@union(createArray(json(concat('{\"table\":\"', variables('combined_tables')[0].name, '\",\"env\":\"', pipeline().parameters.env, '\"}'))), createArray(json(concat('{\"table\":\"', variables('combined_tables')[1].name, '\",\"env\":\"', pipeline().parameters.env, '\"}'))), activity('LookupAdditionalTables').output.value)"
          },
          "activities": [
            {
              "name": "SetCurrentTable",
              "type": "SetVariable",
              "dependsOn": [],
              "typeProperties": {
                "variableName": "current_table",
                "value": {
                  "type": "Expression",
                  "value": "@if(contains(item(), 'table'), item().table, item().table_name)"
                }
              }
            },
            {
              "name": "CheckTableEligibility",
              "type": "IfCondition",
              "dependsOn": [
                {
                  "activity": "SetCurrentTable",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "typeProperties": {
                "expression": {
                  "type": "Expression",
                  "value": "@and(not(equals(variables('current_table'), '')), equals(pipeline().parameters.env, 'dev'))"
                },
                "ifTrueActivities": [
                  {
                    "name": "SetProcessingFlag",
                    "type": "SetVariable",
                    "dependsOn": [],
                    "typeProperties": {
                      "variableName": "processing_flag",
                      "value": {
                        "type": "Expression",
                        "value": "@string(true)"
                      }
                    }
                  },
                  {
                    "name": "CopyTableData",
                    "type": "Copy",
                    "dependsOn": [
                      {
                        "activity": "SetProcessingFlag",
                        "dependencyConditions": [
                          "Succeeded"
                        ]
                      }
                    ],
                    "typeProperties": {
                      "source": {
                        "type": "AzureSqlSource",
                        "sql_reader_query": {
                          "type": "Expression",
                          "value": "@concat('SELECT * FROM ', pipeline().parameters.env, '.dbo.', variables('current_table'), ' WHERE batch_id = ''', pipeline().parameters.batch_id, '''')"
                        }
                      },
                      "sink": {
                        "type": "AzureDatabricksDeltaLakeSink"
                      },
                      "translator": {
                        "type": "TabularTranslator",
                        "mappings": [
                          {
                            "source": {
                              "name": "src_col"
                            },
                            "sink": {
                              "name": "tgt_col",
                              "type": "String"
                            }
                          },
                          {
                            "source": {
                              "name": "batch_id"
                            },
                            "sink": {
                              "name": "batch_id",
                              "type": "String"
                            }
                          },
                          {
                            "source": {
                              "name": "load_ts"
                            },
                            "sink": {
                              "name": "load_timestamp",
                              "type": "String"
                            }
                          }
                        ]
                      },
                      "enableStaging": false
                    },
                    "inputs": [
                      {
                        "referenceName": "ds_sql_source",
                        "type": "DatasetReference"
                      }
                    ],
                    "outputs": [
                      {
                        "referenceName": "ds_delta_sink",
                        "type": "DatasetReference"
                      }
                    ],
                    "input_dataset_definitions": [
                      {
                        "type": "AzureSqlSource",
                        "schema": [],
                        "linkedServiceName": {
                          "referenceName": "ls_sql",
                          "type": "LinkedServiceReference"
                        }
                      }
                    ],
                    "output_dataset_definitions": [
                      {
                        "type": "AzureDatabricksDeltaLakeSink",
                        "schema": [],
                        "linkedServiceName": {
                          "referenceName": "ls_delta",
                          "type": "LinkedServiceReference"
                        }
                      }
                    ]
                  }
                ],
                "ifFalseActivities": []
              }
            }
          ]
        }
      }
    ]
  }
}