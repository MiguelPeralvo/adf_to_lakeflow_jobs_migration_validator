{
  "name": "nested_dynamic_dataset_references",
  "properties": {
    "parameters": {
      "source_system": {
        "type": "String",
        "defaultValue": "erp"
      },
      "entity": {
        "type": "String",
        "defaultValue": "customers"
      },
      "load_date": {
        "type": "String",
        "defaultValue": "2024-01-15T00:00:00Z"
      },
      "env": {
        "type": "String",
        "defaultValue": "dev"
      }
    },
    "variables": {
      "base_path": {
        "type": "String",
        "defaultValue": ""
      },
      "dataset_folder": {
        "type": "String",
        "defaultValue": ""
      },
      "full_dynamic_path": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "LookupPathConfig",
        "type": "Lookup",
        "dependsOn": [],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sql_reader_query": {
              "type": "Expression",
              "value": "@concat('SELECT base_path, path_prefix, path_suffix FROM dbo.dataset_config WHERE source_system = ''', pipeline().parameters.source_system, ''' AND entity = ''', pipeline().parameters.entity, ''' AND env = ''', pipeline().parameters.env, '''')"
            }
          },
          "dataset": {
            "referenceName": "ds_sql_config",
            "type": "DatasetReference"
          },
          "firstRowOnly": true,
          "input_dataset_definitions": [
            {
              "type": "AzureSqlSource",
              "schema": [],
              "linkedServiceName": {
                "referenceName": "ls_sql",
                "type": "LinkedServiceReference"
              }
            }
          ]
        }
      },
      {
        "name": "SetBasePathVariable",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "LookupPathConfig",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "base_path",
          "value": {
            "type": "Expression",
            "value": "@concat(activity('LookupPathConfig').output.firstRow.base_path, '/', pipeline().parameters.env, '/', activity('LookupPathConfig').output.firstRow.path_prefix)"
          }
        }
      },
      {
        "name": "SetDatasetFolderVariable",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "SetBasePathVariable",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "dataset_folder",
          "value": {
            "type": "Expression",
            "value": "@concat(pipeline().parameters.source_system, '/', pipeline().parameters.entity, '/', formatDateTime(pipeline().parameters.load_date, 'yyyy'), '/', formatDateTime(pipeline().parameters.load_date, 'MM'), '/', formatDateTime(pipeline().parameters.load_date, 'dd'))"
          }
        }
      },
      {
        "name": "SetFullDynamicPath",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "SetDatasetFolderVariable",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "full_dynamic_path",
          "value": {
            "type": "Expression",
            "value": "@concat(variables('base_path'), '/', variables('dataset_folder'), '/', concat(activity('LookupPathConfig').output.firstRow.path_suffix, '_', formatDateTime(pipeline().parameters.load_date, 'yyyyMMdd_HHmmss'), '.parquet'))"
          }
        }
      },
      {
        "name": "CopyToDataLake",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "SetFullDynamicPath",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.01:00:00",
          "retry": 3,
          "retryIntervalInSeconds": 60
        },
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sql_reader_query": {
              "type": "Expression",
              "value": "@concat('SELECT * FROM ', pipeline().parameters.source_system, '.dbo.', pipeline().parameters.entity, ' WHERE modified_date >= ''', formatDateTime(pipeline().parameters.load_date, 'yyyy-MM-dd'), '''')"
            }
          },
          "sink": {
            "type": "AzureDatabricksDeltaLakeSink"
          },
          "enableStaging": false,
          "translator": {
            "type": "TabularTranslator",
            "mappings": [
              {
                "source": {
                  "name": "id"
                },
                "sink": {
                  "name": "id",
                  "type": "String"
                }
              },
              {
                "source": {
                  "name": "name"
                },
                "sink": {
                  "name": "name",
                  "type": "String"
                }
              },
              {
                "source": {
                  "name": "modified_date"
                },
                "sink": {
                  "name": "modified_date",
                  "type": "String"
                }
              },
              {
                "source": {
                  "name": "src_col"
                },
                "sink": {
                  "name": "tgt_col",
                  "type": "String"
                }
              }
            ]
          },
          "datasetParameters": {
            "source": {},
            "sink": {
              "dynamic_path": {
                "type": "Expression",
                "value": "@variables('full_dynamic_path')"
              }
            }
          },
          "input_dataset_definitions": [
            {
              "type": "AzureSqlSource",
              "schema": [],
              "linkedServiceName": {
                "referenceName": "ls_sql",
                "type": "LinkedServiceReference"
              }
            }
          ],
          "output_dataset_definitions": [
            {
              "type": "AzureDatabricksDeltaLakeSink",
              "schema": [],
              "linkedServiceName": {
                "referenceName": "ls_delta",
                "type": "LinkedServiceReference"
              }
            }
          ]
        },
        "inputs": [
          {
            "referenceName": "ds_sql_source",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_delta_sink",
            "type": "DatasetReference",
            "parameters": {
              "dynamic_path": {
                "type": "Expression",
                "value": "@variables('full_dynamic_path')"
              }
            }
          }
        ]
      },
      {
        "name": "NotifyCompletion",
        "type": "WebActivity",
        "dependsOn": [
          {
            "activity": "CopyToDataLake",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.00:05:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "url": {
            "type": "Expression",
            "value": "@concat('https://api-', pipeline().parameters.env, '.company.com/notifications/pipeline-complete')"
          },
          "method": "POST",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "Expression",
            "value": "@json(concat('{\"pipeline\":\"nested_dynamic_dataset_references\",\"source_system\":\"', pipeline().parameters.source_system, '\",\"entity\":\"', pipeline().parameters.entity, '\",\"load_date\":\"', pipeline().parameters.load_date, '\",\"env\":\"', pipeline().parameters.env, '\",\"dynamic_path\":\"', variables('full_dynamic_path'), '\",\"base_path\":\"', variables('base_path'), '\",\"dataset_folder\":\"', variables('dataset_folder'), '\",\"lookup_base_path\":\"', activity('LookupPathConfig').output.firstRow.base_path, '\",\"lookup_prefix\":\"', activity('LookupPathConfig').output.firstRow.path_prefix, '\",\"lookup_suffix\":\"', activity('LookupPathConfig').output.firstRow.path_suffix, '\",\"formatted_date\":\"', formatDateTime(pipeline().parameters.load_date, 'yyyyMMdd'), '\",\"status\":\"succeeded\"}'))"
          }
        }
      }
    ]
  }
}