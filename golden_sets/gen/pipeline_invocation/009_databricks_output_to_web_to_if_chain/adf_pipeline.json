{
  "name": "databricks_output_to_web_to_if_chain",
  "properties": {
    "parameters": {
      "notebook_path": {
        "type": "String",
        "defaultValue": "/Shared/etl/process_data"
      },
      "api_endpoint": {
        "type": "String",
        "defaultValue": "https://api.example.com/v1/validate"
      },
      "env": {
        "type": "String",
        "defaultValue": "dev"
      }
    },
    "variables": {
      "notebook_result": {
        "type": "String",
        "defaultValue": ""
      },
      "validation_status": {
        "type": "String",
        "defaultValue": "pending"
      }
    },
    "activities": [
      {
        "name": "RunProcessingNotebook",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "policy": {
          "timeout": "01:00:00",
          "retry": 2,
          "retryIntervalInSeconds": 60
        },
        "typeProperties": {
          "notebookPath": {
            "type": "Expression",
            "value": "@pipeline().parameters.notebook_path"
          },
          "baseParameters": {
            "environment": "@pipeline().parameters.env",
            "run_id": "@pipeline().RunId"
          }
        },
        "linkedServiceName": {
          "referenceName": "ls_adb_workspace",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "SetNotebookOutput",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "RunProcessingNotebook",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "notebook_result",
          "value": {
            "type": "Expression",
            "value": "@string(activity('RunProcessingNotebook').output.runOutput)"
          }
        }
      },
      {
        "name": "CallValidationAPI",
        "type": "WebActivity",
        "dependsOn": [
          {
            "activity": "SetNotebookOutput",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "00:10:00",
          "retry": 3,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "url": {
            "type": "Expression",
            "value": "@concat(pipeline().parameters.api_endpoint, '/', pipeline().parameters.env, '/validate')"
          },
          "method": "POST",
          "headers": {
            "Content-Type": "application/json",
            "X-Pipeline-RunId": "@pipeline().RunId"
          },
          "body": {
            "type": "Expression",
            "value": "@json(concat('{\"notebook_run_output\":', variables('notebook_result'), ',\"environment\":\"', pipeline().parameters.env, '\",\"pipeline_run_id\":\"', pipeline().RunId, '\"}'))"
          }
        }
      },
      {
        "name": "EvaluateNotebookAndApiResults",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "CallValidationAPI",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "expression": {
            "type": "Expression",
            "value": "@and(equals(activity('CallValidationAPI').output.status, 'valid'), greater(int(activity('RunProcessingNotebook').output.runOutput), 0))"
          },
          "ifTrueActivities": [
            {
              "name": "CopyValidatedData",
              "type": "Copy",
              "dependsOn": [],
              "policy": {
                "timeout": "01:00:00",
                "retry": 1,
                "retryIntervalInSeconds": 60
              },
              "typeProperties": {
                "source": {
                  "type": "AzureSqlSource",
                  "sql_reader_query": {
                    "type": "Expression",
                    "value": "@concat('SELECT * FROM staging.processed_records WHERE environment = ''', pipeline().parameters.env, ''' AND batch_id = ', activity('RunProcessingNotebook').output.runOutput)"
                  }
                },
                "sink": {
                  "type": "AzureDatabricksDeltaLakeSink"
                },
                "translator": {
                  "type": "TabularTranslator",
                  "mappings": [
                    {
                      "source": {
                        "name": "src_col"
                      },
                      "sink": {
                        "name": "tgt_col",
                        "type": "String"
                      }
                    },
                    {
                      "source": {
                        "name": "record_id"
                      },
                      "sink": {
                        "name": "record_id",
                        "type": "String"
                      }
                    },
                    {
                      "source": {
                        "name": "processed_ts"
                      },
                      "sink": {
                        "name": "processed_timestamp",
                        "type": "String"
                      }
                    },
                    {
                      "source": {
                        "name": "status_code"
                      },
                      "sink": {
                        "name": "status",
                        "type": "String"
                      }
                    }
                  ]
                },
                "enableStaging": false
              },
              "input_dataset_definitions": [
                {
                  "type": "AzureSqlSource",
                  "schema": [],
                  "linkedServiceName": {
                    "referenceName": "ls_sql",
                    "type": "LinkedServiceReference"
                  }
                }
              ],
              "output_dataset_definitions": [
                {
                  "type": "AzureDatabricksDeltaLakeSink",
                  "schema": [],
                  "linkedServiceName": {
                    "referenceName": "ls_delta",
                    "type": "LinkedServiceReference"
                  }
                }
              ]
            }
          ],
          "ifFalseActivities": [
            {
              "name": "LogValidationFailure",
              "type": "WebActivity",
              "dependsOn": [],
              "policy": {
                "timeout": "00:05:00",
                "retry": 1,
                "retryIntervalInSeconds": 15
              },
              "typeProperties": {
                "url": {
                  "type": "Expression",
                  "value": "@concat(pipeline().parameters.api_endpoint, '/', pipeline().parameters.env, '/log-failure')"
                },
                "method": "POST",
                "headers": {
                  "Content-Type": "application/json"
                },
                "body": {
                  "type": "Expression",
                  "value": "@json(concat('{\"pipeline_run_id\":\"', pipeline().RunId, '\",\"notebook_output\":', variables('notebook_result'), ',\"api_response\":', string(activity('CallValidationAPI').output), ',\"failure_reason\":\"Validation did not pass combined notebook and API check\"}'))"
                }
              }
            }
          ]
        }
      }
    ]
  }
}