{
  "name": "nested_multi_lookup_aggregator",
  "properties": {
    "parameters": {
      "config_table_a": {
        "type": "String",
        "defaultValue": "dbo.ConfigA"
      },
      "config_table_b": {
        "type": "String",
        "defaultValue": "dbo.ConfigB"
      },
      "env": {
        "type": "String",
        "defaultValue": "dev"
      },
      "merge_strategy": {
        "type": "String",
        "defaultValue": "upsert"
      }
    },
    "variables": {
      "merged_configs": {
        "type": "Array",
        "defaultValue": []
      },
      "record_count": {
        "type": "String",
        "defaultValue": "0"
      },
      "selected_strategy": {
        "type": "String",
        "defaultValue": ""
      },
      "filter_expression": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "LookupConfigA",
        "type": "Lookup",
        "dependsOn": [],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sql_reader_query": {
              "type": "Expression",
              "value": "@concat('SELECT * FROM ', pipeline().parameters.config_table_a, ' WHERE env = ''', pipeline().parameters.env, '''')"
            }
          },
          "dataset": {
            "referenceName": "ds_sql_config",
            "type": "DatasetReference"
          },
          "firstRowOnly": false
        },
        "input_dataset_definitions": [
          {
            "type": "AzureSqlSource",
            "schema": [],
            "linkedServiceName": {
              "referenceName": "ls_sql",
              "type": "LinkedServiceReference"
            }
          }
        ]
      },
      {
        "name": "LookupConfigB",
        "type": "Lookup",
        "dependsOn": [],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sql_reader_query": {
              "type": "Expression",
              "value": "@concat('SELECT * FROM ', pipeline().parameters.config_table_b, ' WHERE env = ''', pipeline().parameters.env, ''' AND active = 1')"
            }
          },
          "dataset": {
            "referenceName": "ds_sql_config",
            "type": "DatasetReference"
          },
          "firstRowOnly": false
        },
        "input_dataset_definitions": [
          {
            "type": "AzureSqlSource",
            "schema": [],
            "linkedServiceName": {
              "referenceName": "ls_sql",
              "type": "LinkedServiceReference"
            }
          }
        ]
      },
      {
        "name": "SetMergedConfigs",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "LookupConfigA",
            "dependencyConditions": [
              "Succeeded"
            ]
          },
          {
            "activity": "LookupConfigB",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "merged_configs",
          "value": {
            "type": "Expression",
            "value": "@union(coalesce(activity('LookupConfigA').output.value, createArray()), coalesce(activity('LookupConfigB').output.value, createArray()))"
          }
        }
      },
      {
        "name": "SetRecordCount",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "SetMergedConfigs",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "record_count",
          "value": {
            "type": "Expression",
            "value": "@string(add(length(coalesce(activity('LookupConfigA').output.value, createArray())), length(coalesce(activity('LookupConfigB').output.value, createArray()))))"
          }
        }
      },
      {
        "name": "SetSelectedStrategy",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "LookupConfigA",
            "dependencyConditions": [
              "Succeeded"
            ]
          },
          {
            "activity": "LookupConfigB",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "selected_strategy",
          "value": {
            "type": "Expression",
            "value": "@coalesce(if(greater(length(coalesce(activity('LookupConfigA').output.value, createArray())), 0), activity('LookupConfigA').output.value[0].strategy, null), if(greater(length(coalesce(activity('LookupConfigB').output.value, createArray())), 0), activity('LookupConfigB').output.value[0].strategy, null), pipeline().parameters.merge_strategy)"
          }
        }
      },
      {
        "name": "SetFilterExpression",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "SetRecordCount",
            "dependencyConditions": [
              "Succeeded"
            ]
          },
          {
            "activity": "SetSelectedStrategy",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "variableName": "filter_expression",
          "value": {
            "type": "Expression",
            "value": "@concat('strategy=''', variables('selected_strategy'), ''' AND record_count=', variables('record_count'), ' AND env=''', pipeline().parameters.env, '''')"
          }
        }
      },
      {
        "name": "CheckRecordsExist",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "SetFilterExpression",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "expression": {
            "type": "Expression",
            "value": "@greater(int(variables('record_count')), 0)"
          },
          "ifTrueActivities": [
            {
              "name": "ForEachMergedConfig",
              "type": "ForEach",
              "dependsOn": [],
              "typeProperties": {
                "isSequential": false,
                "batchCount": 10,
                "items": {
                  "type": "Expression",
                  "value": "@createArray(coalesce(first(coalesce(activity('LookupConfigA').output.value, createArray())), json('{\"table_name\":\"fallback_a\",\"schema\":\"dbo\"}')), coalesce(first(coalesce(activity('LookupConfigB').output.value, createArray())), json('{\"table_name\":\"fallback_b\",\"schema\":\"dbo\"}')))"
                },
                "activities": [
                  {
                    "name": "CopyConfigData",
                    "type": "Copy",
                    "dependsOn": [],
                    "policy": {
                      "timeout": "0.01:00:00",
                      "retry": 3,
                      "retryIntervalInSeconds": 60
                    },
                    "typeProperties": {
                      "source": {
                        "type": "AzureSqlSource",
                        "sql_reader_query": {
                          "type": "Expression",
                          "value": "@concat('SELECT * FROM ', coalesce(item().schema, 'dbo'), '.', coalesce(item().table_name, 'default_table'), ' WHERE env = ''', pipeline().parameters.env, ''' AND merge_strategy = ''', coalesce(variables('selected_strategy'), pipeline().parameters.merge_strategy), '''')"
                        }
                      },
                      "sink": {
                        "type": "AzureDatabricksDeltaLakeSink"
                      },
                      "translator": {
                        "type": "TabularTranslator",
                        "mappings": [
                          {
                            "source": {
                              "name": "src_col"
                            },
                            "sink": {
                              "name": "tgt_col",
                              "type": "String"
                            }
                          },
                          {
                            "source": {
                              "name": "env"
                            },
                            "sink": {
                              "name": "environment",
                              "type": "String"
                            }
                          },
                          {
                            "source": {
                              "name": "strategy"
                            },
                            "sink": {
                              "name": "merge_strategy",
                              "type": "String"
                            }
                          }
                        ]
                      },
                      "enableStaging": false
                    },
                    "inputs": [
                      {
                        "referenceName": "ds_sql_source",
                        "type": "DatasetReference"
                      }
                    ],
                    "outputs": [
                      {
                        "referenceName": "ds_delta_sink",
                        "type": "DatasetReference"
                      }
                    ],
                    "input_dataset_definitions": [
                      {
                        "type": "AzureSqlSource",
                        "schema": [],
                        "linkedServiceName": {
                          "referenceName": "ls_sql",
                          "type": "LinkedServiceReference"
                        }
                      }
                    ],
                    "output_dataset_definitions": [
                      {
                        "type": "AzureDatabricksDeltaLakeSink",
                        "schema": [],
                        "linkedServiceName": {
                          "referenceName": "ls_delta",
                          "type": "LinkedServiceReference"
                        }
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "ifFalseActivities": []
        }
      },
      {
        "name": "ForEachAggregatedRecord",
        "type": "ForEach",
        "dependsOn": [
          {
            "activity": "CheckRecordsExist",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "isSequential": true,
          "batchCount": 1,
          "items": {
            "type": "Expression",
            "value": "@createArray(json(concat('{\"total\":', variables('record_count'), ',\"strategy\":\"', variables('selected_strategy'), '\",\"env\":\"', pipeline().parameters.env, '\"}')))"
          },
          "activities": [
            {
              "name": "CopyAggregatedResults",
              "type": "Copy",
              "dependsOn": [],
              "policy": {
                "timeout": "0.01:00:00",
                "retry": 2,
                "retryIntervalInSeconds": 30
              },
              "typeProperties": {
                "source": {
                  "type": "AzureSqlSource",
                  "sql_reader_query": {
                    "type": "Expression",
                    "value": "@concat('SELECT ''', coalesce(item().strategy, 'default'), ''' AS strategy, ', coalesce(item().total, '0'), ' AS total_records, ''', coalesce(item().env, pipeline().parameters.env), ''' AS environment FROM ', pipeline().parameters.config_table_a, ' UNION ALL SELECT ''', coalesce(item().strategy, 'default'), ''', ', coalesce(item().total, '0'), ', ''', coalesce(item().env, pipeline().parameters.env), ''' FROM ', pipeline().parameters.config_table_b)"
                  }
                },
                "sink": {
                  "type": "AzureDatabricksDeltaLakeSink"
                },
                "translator": {
                  "type": "TabularTranslator",
                  "mappings": [
                    {
                      "source": {
                        "name": "src_col"
                      },
                      "sink": {
                        "name": "tgt_col",
                        "type": "String"
                      }
                    }
                  ]
                },
                "enableStaging": false
              },
              "inputs": [
                {
                  "referenceName": "ds_sql_aggregated",
                  "type": "DatasetReference"
                }
              ],
              "outputs": [
                {
                  "referenceName": "ds_delta_aggregated",
                  "type": "DatasetReference"
                }
              ],
              "input_dataset_definitions": [
                {
                  "type": "AzureSqlSource",
                  "schema": [],
                  "linkedServiceName": {
                    "referenceName": "ls_sql",
                    "type": "LinkedServiceReference"
                  }
                }
              ],
              "output_dataset_definitions": [
                {
                  "type": "AzureDatabricksDeltaLakeSink",
                  "schema": [],
                  "linkedServiceName": {
                    "referenceName": "ls_delta",
                    "type": "LinkedServiceReference"
                  }
                }
              ]
            }
          ]
        }
      }
    ]
  }
}