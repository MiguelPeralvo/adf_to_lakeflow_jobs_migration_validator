{
  "name": "foreach_nested_foreach_conditions",
  "properties": {
    "parameters": {
      "batch_id": {
        "type": "String",
        "defaultValue": "batch_001"
      },
      "partition_count": {
        "type": "Int",
        "defaultValue": 4
      },
      "env": {
        "type": "String",
        "defaultValue": "dev"
      },
      "table_list": {
        "type": "Array",
        "defaultValue": [
          "customers",
          "orders",
          "products"
        ]
      }
    },
    "variables": {
      "current_table": {
        "type": "String",
        "defaultValue": ""
      },
      "processing_status": {
        "type": "String",
        "defaultValue": "pending"
      }
    },
    "activities": [
      {
        "name": "LookupTableMetadata",
        "type": "Lookup",
        "dependsOn": [],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sql_reader_query": {
              "type": "Expression",
              "value": "@concat('SELECT table_name, partition_key, is_active, row_count FROM metadata.table_config WHERE batch_id = ''', pipeline().parameters.batch_id, ''' AND environment = ''', pipeline().parameters.env, '''')"
            }
          },
          "firstRowOnly": false
        },
        "input_dataset_definitions": [
          {
            "type": "AzureSqlSource",
            "schema": [],
            "linkedServiceName": {
              "referenceName": "ls_sql",
              "type": "LinkedServiceReference"
            }
          }
        ]
      },
      {
        "name": "ForEachTable",
        "type": "ForEach",
        "dependsOn": [
          {
            "activity": "LookupTableMetadata",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "isSequential": false,
          "batchCount": 4,
          "items": {
            "type": "Expression",
            "value": "@activity('LookupTableMetadata').output.value"
          },
          "activities": [
            {
              "name": "ForEachPartition",
              "type": "ForEach",
              "dependsOn": [],
              "typeProperties": {
                "isSequential": true,
                "items": {
                  "type": "Expression",
                  "value": "@createArray(0,1,2,3)"
                },
                "activities": [
                  {
                    "name": "CheckTableActive",
                    "type": "IfCondition",
                    "dependsOn": [],
                    "typeProperties": {
                      "expression": {
                        "type": "Expression",
                        "value": "@equals(item().is_active, true)"
                      },
                      "ifTrueActivities": [
                        {
                          "name": "CheckRowCountThreshold",
                          "type": "IfCondition",
                          "dependsOn": [],
                          "typeProperties": {
                            "expression": {
                              "type": "Expression",
                              "value": "@greater(item().row_count, 1000)"
                            },
                            "ifTrueActivities": [
                              {
                                "name": "CopyPartitionData",
                                "type": "Copy",
                                "dependsOn": [],
                                "policy": {
                                  "timeout": "0.01:00:00",
                                  "retry": 3,
                                  "retryIntervalInSeconds": 60
                                },
                                "typeProperties": {
                                  "source": {
                                    "type": "AzureSqlSource",
                                    "sql_reader_query": {
                                      "type": "Expression",
                                      "value": "@concat('SELECT * FROM ', pipeline().parameters.env, '.', item().table_name, ' WHERE partition_id = ', string(item()), ' AND batch_id = ''', pipeline().parameters.batch_id, '''')"
                                    }
                                  },
                                  "sink": {
                                    "type": "AzureDatabricksDeltaLakeSink"
                                  },
                                  "translator": {
                                    "type": "TabularTranslator",
                                    "mappings": [
                                      {
                                        "source": {
                                          "name": "src_col"
                                        },
                                        "sink": {
                                          "name": "tgt_col",
                                          "type": "String"
                                        }
                                      }
                                    ]
                                  },
                                  "enableStaging": false
                                },
                                "input_dataset_definitions": [
                                  {
                                    "type": "AzureSqlSource",
                                    "schema": [],
                                    "linkedServiceName": {
                                      "referenceName": "ls_sql",
                                      "type": "LinkedServiceReference"
                                    }
                                  }
                                ],
                                "output_dataset_definitions": [
                                  {
                                    "type": "AzureDatabricksDeltaLakeSink",
                                    "schema": [],
                                    "linkedServiceName": {
                                      "referenceName": "ls_delta",
                                      "type": "LinkedServiceReference"
                                    }
                                  }
                                ]
                              }
                            ],
                            "ifFalseActivities": [
                              {
                                "name": "SetStatusSkipped",
                                "type": "SetVariable",
                                "dependsOn": [],
                                "typeProperties": {
                                  "variableName": "processing_status",
                                  "value": {
                                    "type": "Expression",
                                    "value": "@concat('skipped_low_row_count_', item().table_name, '_partition_', string(item()))"
                                  }
                                }
                              }
                            ]
                          }
                        }
                      ],
                      "ifFalseActivities": [
                        {
                          "name": "NotifyInactiveTable",
                          "type": "WebActivity",
                          "dependsOn": [],
                          "policy": {
                            "timeout": "0.00:05:00",
                            "retry": 1,
                            "retryIntervalInSeconds": 30
                          },
                          "typeProperties": {
                            "url": {
                              "type": "Expression",
                              "value": "@concat('https://hooks.example.com/api/', pipeline().parameters.env, '/notifications')"
                            },
                            "method": "POST",
                            "headers": {
                              "Content-Type": "application/json"
                            },
                            "body": {
                              "type": "Expression",
                              "value": "@json(concat('{\"batch_id\":\"', pipeline().parameters.batch_id, '\",\"table\":\"', item().table_name, '\",\"partition\":', string(item()), ',\"status\":\"inactive_skipped\",\"env\":\"', pipeline().parameters.env, '\"}'))"
                            }
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}