{
  "name": "nested_split_connection_parser",
  "properties": {
    "parameters": {
      "connection_string": {
        "type": "String",
        "defaultValue": "Server=myserver;Database=mydb;User=admin"
      },
      "fallback_db": {
        "type": "String",
        "defaultValue": "default_db"
      }
    },
    "variables": {
      "server_name": {
        "type": "String",
        "defaultValue": ""
      },
      "database_name": {
        "type": "String",
        "defaultValue": ""
      },
      "is_valid": {
        "type": "String",
        "defaultValue": "false"
      }
    },
    "activities": [
      {
        "name": "ExtractServer",
        "type": "SetVariable",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "variableName": "server_name",
          "value": {
            "type": "Expression",
            "value": "@split(split(pipeline().parameters.connection_string, ';')[0], '=')[1]"
          }
        }
      },
      {
        "name": "ExtractDatabase",
        "type": "SetVariable",
        "dependsOn": [
          {
            "activity": "ExtractServer",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "variableName": "database_name",
          "value": {
            "type": "Expression",
            "value": "@split(split(pipeline().parameters.connection_string, ';')[1], '=')[1]"
          }
        }
      },
      {
        "name": "ValidateConnection",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "ExtractDatabase",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "type": "Expression",
            "value": "@not(empty(variables('server_name')))"
          },
          "ifTrueActivities": [
            {
              "name": "MarkValid",
              "type": "SetVariable",
              "dependsOn": [],
              "userProperties": [],
              "typeProperties": {
                "variableName": "is_valid",
                "value": {
                  "type": "Expression",
                  "value": "@string('true')"
                }
              }
            }
          ],
          "ifFalseActivities": [
            {
              "name": "UseFallback",
              "type": "SetVariable",
              "dependsOn": [],
              "userProperties": [],
              "typeProperties": {
                "variableName": "database_name",
                "value": {
                  "type": "Expression",
                  "value": "@pipeline().parameters.fallback_db"
                }
              }
            }
          ]
        }
      },
      {
        "name": "LookupSchema",
        "type": "Lookup",
        "dependsOn": [
          {
            "activity": "ValidateConnection",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sqlReaderQuery": {
              "type": "Expression",
              "value": "@concat('SELECT TOP 1 * FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_CATALOG = ''', variables('database_name'), '''')"
            }
          },
          "firstRowOnly": true
        }
      }
    ]
  }
}