{
  "name": "intersection_variant_000",
  "properties": {
    "parameters": {
      "requested_modules": {
        "type": "Array",
        "defaultValue": [
          "all"
        ]
      },
      "run_flag": {
        "type": "String",
        "defaultValue": "enabled"
      }
    },
    "variables": {
      "status_flag": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "CheckCoreAnalytics",
        "type": "IfCondition",
        "dependsOn": [],
        "userProperties": [],
        "typeProperties": {
          "expression": {
            "type": "Expression",
            "value": "@not(empty(intersection(pipeline().parameters.requested_modules, createArray('all', 'core', 'analytics', 'core_analytics'))))"
          },
          "ifTrueActivities": [
            {
              "name": "SetTrueFlag",
              "type": "SetVariable",
              "dependsOn": [],
              "userProperties": [],
              "typeProperties": {
                "variableName": "status_flag",
                "value": {
                  "type": "Expression",
                  "value": "@string('true')"
                }
              }
            }
          ],
          "ifFalseActivities": [
            {
              "name": "SetFalseFlag",
              "type": "SetVariable",
              "dependsOn": [],
              "userProperties": [],
              "typeProperties": {
                "variableName": "status_flag",
                "value": {
                  "type": "Expression",
                  "value": "@string('false')"
                }
              }
            }
          ]
        }
      }
    ]
  }
}